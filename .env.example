# Async PostgreSQL connection string — replace user/password/host/dbname as needed
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/medinsight

# Redis connection string
REDIS_URL=redis://localhost:6379

# Google Gemini API key (vision model)
GEMINI_API_KEY=

# Groq API key (reasoning model)
GROQ_API_KEY=

# JWT secret — use a long random string in production
SECRET_KEY=

# JWT algorithm — keep HS256 unless you have a specific reason to change
ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=30
